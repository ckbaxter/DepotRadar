# ================================================================
#  ATH-Tracker – Konfigurationsdatei
#
#  Kopieren und umbenennen:
#    cp config/ath-tracker.yml.example config/ath-tracker.yml
#
#  Copy and rename:
#    cp config/ath-tracker.yml.example config/ath-tracker.yml
# ================================================================

# Zeitzone (IANA-Format)
# Timezone (IANA format)
# Examples: Europe/Berlin | Europe/London | America/New_York
timezone: "Europe/Berlin"

# Handelszeiten / Trading window
# Kurse werden NUR in diesem Zeitfenster abgerufen
# Prices are only fetched within this time window
trading:
  # Handelstage / Trading days
  # 0=Montag/Monday  1=Dienstag/Tuesday  2=Mittwoch/Wednesday
  # 3=Donnerstag/Thursday  4=Freitag/Friday  5=Samstag/Saturday  6=Sonntag/Sunday
  days: [0, 1, 2, 3, 4]

  # Erste Aktualisierung des Tages / First update of the day (hour, 0-23)
  start_hour: 8

  # Keine Aktualisierungen ab dieser Stunde / No updates from this hour onwards
  end_hour: 23

# Standard-Aktualisierungsintervall in Sekunden
# Default refresh interval in seconds
# Can be overridden in the web UI
# 900  = 15 minutes
# 1800 = 30 minutes
# 3600 = 1 hour (default)
# 7200 = 2 hours
refresh_interval_seconds: 3600
